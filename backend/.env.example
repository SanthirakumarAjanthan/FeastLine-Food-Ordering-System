# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=food_ordering_system
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# PayHere Sandbox credentials
# Get these from https://www.payhere.lk/ (Sandbox account)
PAYHERE_MERCHANT_ID=your_sandbox_merchant_id
PAYHERE_MERCHANT_SECRET=your_sandbox_merchant_secret
PAYHERE_MODE=sandbox

# URLs PayHere will redirect/notify to
PAYHERE_RETURN_URL=http://localhost:5173/order-confirmation
PAYHERE_CANCEL_URL=http://localhost:5173/checkout
PAYHERE_NOTIFY_URL=http://localhost:5000/api/payment/notify
